{
  "name": "@pyyupsk/nit",
  "version": "0.2.0",
  "description": "Lightweight zero-dependency Git hooks manager for JavaScript/Node.js projects",
  "license": "MIT",
  "packageManager": "bun@1.3.11",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "nit": "dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "check": "biome check .",
    "dev": "tsup --watch",
    "format": "biome format --write .",
    "knip": "knip",
    "prepare": "bun run ./src/cli.ts install",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@types/bun": "^1.3.12",
    "@vitest/coverage-v8": "^4.1.4",
    "knip": "^6.4.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "nit": {
    "hooks": {
      "pre-commit": {
        "stages": {
          "**/*.{ts,json}": "biome check --write {staged_files}"
        }
      },
      "pre-push": "bun typecheck && bun test && bun run build"
    }
  }
}
