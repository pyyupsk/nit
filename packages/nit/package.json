{
  "name": "@pyyupsk/nit",
  "version": "0.3.1",
  "description": "Lightweight zero-dependency Git hooks manager for JavaScript/Node.js projects",
  "license": "MIT",
  "author": "Pongsakorn Thipayanate <pthipayanate@gmail.com>",
  "homepage": "https://github.com/pyyupsk/nit#readme",
  "bugs": {
    "url": "https://github.com/pyyupsk/nit/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pyyupsk/nit.git",
    "directory": "packages/nit"
  },
  "packageManager": "bun@1.3.11",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "nit": "dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsup",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "dev": "tsup --watch",
    "format": "biome format --write .",
    "knip": "knip",
    "prepare": "bun run ./scripts/prepare.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "^1.3.12",
    "@types/node": "latest",
    "@vitest/coverage-v8": "^4.1.4",
    "knip": "^6.4.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  }
}
